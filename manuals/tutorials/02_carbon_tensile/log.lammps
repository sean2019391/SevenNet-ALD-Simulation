	# minimize = perform energy minimization of the system
	# minimize etol ftol maxiter maxeval
		# etol = stopping tolereance for energy = 1.0e-20 = 이것보다 iteration사이 에너지 차이 적으면 멈춤 = target energy difference
		# ftol = stopping tolerance for force = 1.0e-20 = target maximum force on any atom = 각 원자의 힘이 이것보다 작으면 멈춤
		# maxiter = max iterations of minimizer = 100000 = minimization의 iteration의 한계 횟수
		# maxeval = max number of force/energy evaluation = 100000 = if calculated forces acting on atoms reach 100000, it stops

variable Lx_tmp equal lx		# 교수님 질문: 왜 굳이 이렇게 두번에 썼나?
variable Lx0 equal ${Lx_tmp}
variable Lx0 equal 12.520248199133

variable dLx equal "v_Lx0*v_strain_incre"		   # incremental change in the box length with incremental strain
variable dtoMin equal "v_Lx0*v_MAX_strain_abs"		   # total change in box length with maximum strain

dump d all custom 10 tensile_${T_temp}.trj type x y z	   # 10 스텝마다 output
dump d all custom 10 tensile_5000.trj type x y z	   

# ----- Start loop
label looplabel					# label = can "jumped" to
variable loopcounter loop ${MAXcount}
variable loopcounter loop 1001
	# loop = iterates over a series of commands a specific number of times
	# 1부터 MAXcount (1001)까지 for loop

variable EPOT equal pe
variable NP equal atoms
variable EPOTperatom equal pe/${NP}		# potential energy per atom
variable EPOTperatom equal pe/216		
variable strain equal lx/v_Lx0-1.0		# strain = (current box length) / (initial box length)
variable sigmaxxGPa equal -pxx*0.0001		# convert stress components to GPa (1 bar = 0.0001 GPa)
	# pxx = pressure in x direction
variable sigmayyGPa equal -pyy*0.0001
	# pyy = pressure in y direction
	# x,y 방향으로 압력

# this run is necessary to make LAMMPS to compute pxx
fix tmp all print 1 "${sigmaxxGPa} ${sigmayyGPa}" 	# just to ensure Pxx & Pyy computation
	# print stress in x, y direction every 1 timestep
fix tmp1 all setforce 0.0 0.0 0.0			# 원자에 가하는 힘을 0으로 바꿈. 계산중 혹시 모르니까
	# setfofce = set each component of force on each atom to the specified values fx, fy, fz
		# overwrite the forces acting on atoms --> zero out the foce on every atom in 3 direction
