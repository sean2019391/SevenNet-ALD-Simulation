  using 1 OpenMP thread(s) per MPI task
# ---------- Initialization
units 		metal
boundary 	p p p
atom_style 	charge		# electrostatics에 유용

# ---------- load structure file
variable T_temp equal 5000
read_data C_done_${T_temp}.data
read_data C_done_5000.data
Reading data file ...
  orthogonal box = (-4.4797515 -4.4797515 -4.4797515) to (8.0404967 8.0404967 8.0404967)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  216 atoms
  reading velocities ...
  216 velocities
  read_data CPU = 0.001 seconds
	# one of three ways to specify simulation box --> create_box, read_restart

# ----- Force field
mass 1 12.011			# 탄소, Carbon
pair_style tersoff		# Tersoff = interatomic interaction에 유용. 특히 Carbon, Silicon, Boron Nitride
pair_coeff * * BNC.tersoff C	# Tersoff Force Field 적용
Reading tersoff potential file BNC.tersoff with DATE: 2013-03-21

# ----- Variables
variable MAX_strain_abs equal 0.1	# Strain = Amount of deformation experienced by body in directio of applied force
variable strain_incre equal 0.0001
variable MAXcount equal "ceil(v_MAX_strain_abs/v_strain_incre)+1"	# Number of Strain steps = Round up 최고압력/압력증가값
	# gives amount of strain each increment
	# MAXcount = 1001

# ----- Initial Minimization
min_style cg						   # 똑같이 Conjugate Gradient
minimize 1.0e-10 1.0e-10 100000 1000000			   # tolerance value = 1.0e-10 , maximum force evaluation = 1,000,000

